{
  "name": "kit",
  "private": true,
  "version": "0.2.0",
  "description": "Kit desktop toolbox for everyday workflows",
  "author": "Manon",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:base": "tsc && vite build",
    "build": "cross-env NODE_ENV=production npm run build:base",
    "build:analyze": "cross-env ANALYZE=1 npm run build && node scripts/build-optimizer.mjs",
    "build:cloudflare": "npm run build:base && cross-env NITRO_PRESET=cloudflare-pages nitro build",
    "build:vercel": "npm run build:base && cross-env NITRO_PRESET=vercel nitro build",
    "build:nitro": "npm run build:base && nitro build",
    "analyze": "cross-env ANALYZE=1 npm run build",
    "build:production": "npm run build && npm run optimize",
    "preview": "vite preview",
    "optimize": "node scripts/build-optimizer.mjs",
    "publish": "node scripts/updater.mjs",
    "changelog": "node scripts/changelog-generator.mjs",
    "changelog:generate": "node scripts/changelog-generator.mjs generate",
    "changelog:release": "node scripts/changelog-generator.mjs release-notes",
    "changelog:test": "node scripts/test-changelog.mjs",
    "release:patch": "npm version patch && npm run changelog:generate && git add CHANGELOG.md && git commit -m 'docs: update changelog' && git push --tags",
    "release:minor": "npm version minor && npm run changelog:generate && git add CHANGELOG.md && git commit -m 'docs: update changelog' && git push --tags",
    "release:major": "npm version major && npm run changelog:generate && git add CHANGELOG.md && git commit -m 'docs: update changelog' && git push --tags",
    "clean": "rm -rf dist node_modules/.vite",
    "ci:build:analyze": "cross-env ANALYZE=1 npm run build && node scripts/build-optimizer.mjs",
    "clean:all": "npm run clean && rm -rf node_modules",
    "ci:check-tools": "node scripts/check-tools.mjs",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "fix:mac": "echo '请使用: ./scripts/fix-mac-gatekeeper.sh <应用路径>' && echo '例如: ./scripts/fix-mac-gatekeeper.sh ~/Downloads/Kit.app'"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@ffmpeg/core": "^0.12.10",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tabler/icons-react": "^3.40.0",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/react-router": "^1.166.7",
    "@tanstack/react-virtual": "^3.13.22",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fflate": "^0.8.2",
    "gifuct-js": "^2.1.2",
    "i18next": "^25.8.18",
    "i18next-browser-languagedetector": "^8.2.1",
    "jsbarcode": "^3.12.3",
    "lucide-react": "^0.577.0",
    "mermaid": "^11.13.0",
    "motion": "^12.36.0",
    "nanoid": "^5.1.6",
    "next-themes": "^0.4.6",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.8",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "vaul": "^1.1.2",
    "web-vitals": "^5.1.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@actions/github": "^9.0.0",
    "@tanstack/router-plugin": "^1.166.7",
    "@types/node": "^25.5.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "nitropack": "^2.13.1",
    "png-to-ico": "^3.0.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "terser": "^5.46.0",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.0",
    "wait-on": "^9.0.4",
    "@tauri-apps/cli": "^2.0.0"
  }
}
